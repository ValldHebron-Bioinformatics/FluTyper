nextflow_process {

    name "Test Process IndividualGraphicReport"
    script "nf_pipeline/modules/IndividualGraphicReport.nf"
    process "IndividualGraphicReport"

    test("Should create the HTML report") {

        when {
            process {
                """
                def sampleId = "19135815"
                def mutationsCsv = file("${projectDir}/tests/data/19135815/19135815_mutations.csv")
                
                input[0] = tuple(sampleId, mutationsCsv)
                """
            }
        }

        then {
            assert process.success

            // Use positional output to avoid named-channel lookup issues in nf-test 0.9.5
            def reportFiles = process.out[0]
            assert reportFiles != null : "Output channel is null. The HTML report was not emitted."
            assert reportFiles.size() == 1

            def htmlFile = path(reportFiles[0])
            assert htmlFile.exists()
        }
    }

}