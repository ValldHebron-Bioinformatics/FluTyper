nextflow_process {

    name "Test Process GetCDS"
    script "nf_pipeline/modules/GetCDS.nf"
    process "GetCDS"

    test("Should successfully extract and trim CDS from sample") {

        when {
            params {
                protocol = "AVIAN"
                protocols = [
                    AVIAN: [
                        // Point to the local test resources directory 
                        resources : "${projectDir}/tests/data/resources"
                    ]
                ]
            }
            process {
                """
                def hTag = "H5"
                def nTag = "N1"
                def sampleId = "19135815"
                def pathotype = "HPAI"
                
                // The directory containing the 'segments' folder
                def sampleDir = file("\${projectDir}/tests/data/19135815")
                
               
                def haFasta = file("\${sampleDir}/tests/data/19135815/segments/HA/19135815_HA.fasta")                

                input[0] = [ hTag, nTag, sampleId, pathotype, sampleDir ]
                """
            }
        }

        then {
            assert process.success
            
            assert process.out.results != null
            assert process.out.results.size() > 0
            
            // process.out.results[0] is the emitted tuple: [sample_id, [list of paths]]
            def sample_id = process.out.results[0][0]
            assert sample_id == "19135815"
            
            // Ensure at least one CDS fasta file was successfully generated and emitted
            def cdsFiles = process.out.results[0][1]
            assert cdsFiles != null
        }
    }
}