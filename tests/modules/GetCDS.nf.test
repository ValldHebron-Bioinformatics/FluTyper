nextflow_process {

    name "Test Process GetCDS"
    script "nf_pipeline/modules/GetCDS.nf"
    process "GetCDS"

    test("Should successfully extract and trim CDS from sample") {

        when {
            process {
                """
                def hTag = "H5"
                def nTag = "N1"
                def sampleId = "19135815"
                def pathotype = "HPAI"
                def sampleDir = file("${projectDir}/tests/data/19135815")

                input[0] = [ hTag, nTag, sampleId, pathotype, sampleDir ]
                """
            }
        }

        then {
            assert process.success
            assert process.out.results.size() > 0 && process.out.aligned.size() > 0
            
            def targetFile = path(process.out.results.get(0)[1].flatten().find { it.toString().endsWith("19135815_HA1_CDS.fasta") })
            def targetAlignedFile = path(process.out.aligned.get(0)[1].flatten().find { it.toString().endsWith("19135815_HA1_CDS_aligned.fasta") })
            
            assert targetFile.exists() && targetAlignedFile.exists()
            
            def unalignedSeq = targetFile.text.split('>')[1].split('\n', 2)[1].replaceAll('\n', '')
            def refSeq = targetAlignedFile.text.split('>')[1].split('\n', 2)[1].replaceAll('\n', '')
            def querySeq = targetAlignedFile.text.split('>')[2].split('\n', 2)[1].replaceAll('\n', '')
            
            assert unalignedSeq.toLowerCase().startsWith("gatcagattt") : "Unaligned sequence missing expected start motif"
            assert refSeq.length() == querySeq.length() : "Alignment failure: Reference and Query lengths do not match"
            assert refSeq.toLowerCase().startsWith("gatcagattt") : "Reference sequence missing expected start motif"
            assert querySeq.toLowerCase().endsWith("gaaaaaga") : "Query sequence missing expected termination motif"
        }
    }
}