nextflow_process {

    name "Test Process GetCDS"
    script "nf_pipeline/modules/GetCDS.nf"
    process "GetCDS"

    test("Should successfully extract and trim CDS from sample") {

        when {
            params {
                protocol = "AVIAN"
                protocols = [
                    AVIAN: [
                        resources : "${projectDir}/protocols/AVIAN/v1"
                    ]
                ]
            }
            process {
                """
                def hTag = "H5"
                def nTag = "N1"
                def sampleId = "19135815"
                def pathotype = "HPAI"
                
                // We pass the tests/data directory. 
                // Nextflow will stage this as a folder named 'data' in the work directory.
                def sampleDir = file("${projectDir}/tests/data/19135815")

                input[0] = [ hTag, nTag, sampleId, pathotype, sampleDir ]
                """
            }
        }

        then {
            assert process.success
            assert process.out.results.size() > 0
            
            def outputFiles = [process.out.results[0][1]].flatten()
            def targetFilePath = outputFiles.find { it.toString().endsWith("19135815_HA-SP_CDS.fasta") }
            assert targetFilePath != null : "The expected file 19135815_HA-SP_CDS.fasta was not generated"
            
            def targetFile = path(targetFilePath)
            
            // Use Java NIO methods to correctly extract the parent folder name
            assert targetFile.getParent().getFileName().toString() == "CDS" : "The file was not placed in a folder explicitly named 'CDS'"
            
            def lines = targetFile.readLines()
            def sequenceLine = lines.find { !it.startsWith(">") }
            
            assert sequenceLine != null : "No sequence data found below the FASTA header"
            assert sequenceLine.toLowerCase().startsWith("gatcagattt") : "Biological accuracy failure: Sequence does not start with 'gatcagattt'"
        }
    }
}