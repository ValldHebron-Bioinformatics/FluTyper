nextflow_process {

    name "Test Process SubtypeDetection"
    script "nf_pipeline/modules/SubtypeDetection.nf"
    process "SubtypeDetection"

    test("H5N1 HPAI sample is typed correctly") {

        when {
            process {
                """
                input[0] = [
                    "19135815",
                    file("${projectDir}/tests/data/19135815/segments/19135815_HA.fasta"),
                    file("${projectDir}/tests/data/19135815/segments/19135815_NA.fasta")
                ]
                """
            }
        }

        then {
            assert process.success
            
            assert process.out.results != null
            assert process.out.results.size() > 0
            
            def csvPath = path(process.out.results[0][1])
            assert csvPath.exists()
            
            def csvText = csvPath.text
            assert csvText.contains("19135815")
            assert csvText.contains("H5N1")
            assert csvText.contains("HPAI")
        }
    }
}