nextflow_process {

    name "Test Process MutationsCompiler"
    script "nf_pipeline/modules/MutationsCompiler.nf"
    process "MutationsCompiler"

    test("Should successfully compile multiple mutation CSVs into Excel reports") {

        when {
            process {
                """
                // 1. Identify the CSV files to compile
                // We'll use the master mutations CSV we verified in the last test
                def mutationCsv = file("${projectDir}/tests/data/19135815/19135815_mutations.csv")
                
                // You can pass a single file in a list, or multiple if you have them
                input[0] = [ mutationCsv ]
                """
            }
        }

        then {
            assert process.success
            
            // The output is a tuple of two Excel files
            assert process.out.results != null
            
            def finalReport = path(process.out.results[0][0])
            def relevantReport = path(process.out.results[0][1])
            
            assert finalReport.exists()
            assert relevantReport.exists()
            
            // Basic check to ensure the files aren't 0 bytes
            assert finalReport.size() > 0
            assert finalReport.getFileName().toString() == "final_mutations_report.xlsx"
        }
    }
}