import groovy.json.JsonSlurper

nextflow_process {

    name "Test Process MutationsCompiler"
    script "nf_pipeline/modules/MutationsCompiler.nf"
    process "MutationsCompiler"

    test("Should successfully compile multiple mutation CSVs into Excel reports") {

        when {
            process {
                """
                input[0] = file("${projectDir}/tests/data/19135815/19135815_mutations.csv")
                """
            }
        }

        then {
            assert process.success
            assert process.out.results.size() > 0 : "Process results channel is empty!"
            
            def finalReport = path(process.out.results.get(0)[0])
            def relevantReport = path(process.out.results.get(0)[1])
            
            assert finalReport.exists() : "final_mutations_report.xlsx was not generated"
            assert relevantReport.exists() : "relevant_mutations.xlsx was not generated"
            
            // Define a helper to check binary files for specific text strings
        def fileContains = { reportPath, text ->
            // The unzip command is used to read the contents of the Excel file without extracting it
            def cmd = "unzip -p ${reportPath}"
            return cmd.execute().text.contains(text)
}

        // Assert that specific mutation effects from your list are present in the final report

            assert fileContains(finalReport, "Decreased virus binding to") : "Missing duck virulence marker in final report"
            assert fileContains(finalReport, "Decreased HA stability") : "Missing mouse virulence marker in final report"
            assert fileContains(finalReport, "Guo H. et al., 2017") : "Missing reference citation in final report"

            // Perform the same check for the relevant mutations subset
            assert fileContains(relevantReport, "Enhanced antiviral response in mice") : "Missing mouse antiviral marker in relevant report"
            assert fileContains(relevantReport, "Fan S. et al., 2009") : "Missing reference citation in relevant report"

            assert finalReport.size() > 1000 : "The final report seems too small to contain data"
        }
    }
}