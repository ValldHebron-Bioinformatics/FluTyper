nextflow_process {

    name "Test Process MutationsCompiler"
    script "nf_pipeline/modules/MutationsCompiler.nf"
    process "MutationsCompiler"

    test("Should successfully compile multiple mutation CSVs into Excel reports") {

        when {
            process {
                """
                // 1. Identify the CSV files to compile
                // We'll use the master mutations CSV we verified in the last test
                def mutationCsv = file("${projectDir}/tests/data/19135815/19135815_mutations.csv")
                
                // You can pass a single file in a list, or multiple if you have them
                input[0] = [ mutationCsv ]
                """
            }
        }

        then {
            assert process.success
            assert process.out.results.size() > 0 : "Process results channel is empty!"
            
            def finalReport = path(process.out.results.get(0)[0])
            def relevantReport = path(process.out.results.get(0)[1])
            
            assert finalReport.exists() : "final_mutations_report.xlsx was not generated"
            assert relevantReport.exists() : "relevant_mutations.xlsx was not generated"
            
            assert finalReport.getFileName().toString() == "final_mutations_report.xlsx"
            assert relevantReport.getFileName().toString() == "relevant_mutations.xlsx"
            
            assert finalReport.size() > 0 : "The final report Excel file is completely empty"
            assert relevantReport.size() > 0 : "The relevant report Excel file is completely empty"
        }
    }
}