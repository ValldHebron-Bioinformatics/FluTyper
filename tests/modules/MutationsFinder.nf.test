nextflow_process {

    name "Test Process MutationsFinder"
    script "nf_pipeline/modules/MutationsFinder.nf"
    process "MutationsFinder"

    test("Should successfully identify mutations against marker database") {

        when {
            params {
                protocol = "AVIAN"
                protocols = [
                    AVIAN: [
                        resources : "${projectDir}/protocols/AVIAN/v1"
                    ]
                ]
                programs = [
                    MutationsDictionary : "${projectDir}/bin/MutationsDictionary.py"
                ]
            }
            process {
                """
                def sampleId = "19135815"
                def hTag = "H5"
                def nTag = "N1"
                def pathotype = "HPAI"
                
                def protDir = file("${projectDir}/tests/data/19135815/proteins")
                def protFiles = protDir.listFiles().findAll { it.name.endsWith(".fasta") }

                input[0] = [ sampleId, protFiles, hTag, nTag, pathotype ]
                """
            }
        }

        then {
            assert process.success
            
            def masterCsv = path(process.out.results[0][2])
            assert masterCsv.exists()

            def csvText = masterCsv.text
            
            assert csvText.contains("SAMPLE_ID,SUBTYPE,PROTEIN,REF_SUBTYPE,POSITION,REFERENCE_AA,QUERY_AA,MARKER,ORIGIN,EFFECT,REFERENCE")
            assert csvText.contains("19135815,H5N1(HPAI),HA1-SP,H5(HPAI),104,M,L,FALSE")
        }
    }
}