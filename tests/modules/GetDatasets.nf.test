nextflow_process {

    name "Test Process GetDatasets"
    script "nf_pipeline/modules/GetDatasets.nf"
    process "GetDatasets"

    test("Should successfully retrieve datasets for H5N1") {

        when {
            params {
                protocol = "AVIAN"
                protocols = [
                    AVIAN: [
                        resources : "${projectDir}/protocols/AVIAN/v1"
                    ]
                ]
            }
            process {
                """
                def mockCsv = file("mock_inferred_subtypes.csv")
                mockCsv.text = 'seqName,inferred_subtype,pathotype\\n19135815,H5N1,HPAI\\n'
                
                input[0] = mockCsv
                """
            }
        }

        then {
            assert process.success
            
            assert process.out[0] != null
            assert process.out[0].size() > 0
            
            def datasetDir = path(process.out[0][0])
            assert datasetDir.exists()
            assert datasetDir.getFileName().toString() == "nextclade_H5_dataset"
        }

    }
}