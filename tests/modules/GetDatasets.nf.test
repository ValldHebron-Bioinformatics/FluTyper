nextflow_process {

    name "Test Process GetDatasets"
    script "nf_pipeline/modules/GetDatasets.nf"
    process "GetDatasets"

    test("Should successfully retrieve datasets for H5N1") {

        when {
            process {
                """
                input[0] = file("${projectDir}/tests/data/19135815/inferred_subtypes.csv")
                """
            }
        }

        then {
            assert process.success
            
            assert process.out[0] != null
            assert process.out[0].size() > 0
            
            def datasetDir = path(process.out[0][0])
            assert datasetDir.exists()
            assert datasetDir.getFileName().toString() == "nextclade_H5_dataset"

            def pathogenJson = datasetDir.resolve("pathogen.json")
            assert pathogenJson.exists() : "Expected pathogen.json file was not found in the dataset directory"
            assert pathogenJson.toFile().length() > 0 : "The pathogen.json file is empty, expected it to contain metadata about the dataset"
        }
    }
}