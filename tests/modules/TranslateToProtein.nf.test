nextflow_process {

    name "Test Process TranslateToProtein"
    script "nf_pipeline/modules/TranslateToProtein.nf"
    process "TranslateToProtein"

    test("Should successfully translate CDS to protein sequences") {

        when {
            process {
                """
                def sampleId = "19135815"
                
                // Use .listFiles() to pass the actual files, not the folder itself
                def cdsDir = file("${projectDir}/tests/data/19135815/CDS")
                def cdsFiles = cdsDir.listFiles().findAll { it.name.endsWith(".fasta") }

                input[0] = [ sampleId, cdsFiles ]
                """
            }
        }

        then {
            assert process.success
            
            def outputFiles = [process.out.results[0][1]].flatten()
            
            def targetFilePath = outputFiles.find { it.toString().endsWith("19135815_HA-SP_PROT.fasta") }
            assert targetFilePath != null : "The expected file 19135815_HA-SP_PROT.fasta was not generated"
            
            def targetFile = path(targetFilePath)
            assert targetFile.exists()
            
            assert targetFile.getParent().getFileName().toString() == "proteins" : "The file was not placed in a folder explicitly named 'proteins'"
            
            def lines = targetFile.readLines()
            def sequenceLine = lines.find { !it.startsWith(">") }
            
            assert sequenceLine != null : "No protein sequence data found below the FASTA header"
            assert sequenceLine.toUpperCase().startsWith("DQICIGYHANN") : "Biological accuracy failure: Sequence does not start with 'DQICIGYHANN'"
        }
    }
}