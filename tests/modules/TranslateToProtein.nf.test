nextflow_process {

    name "Test Process TranslateToProtein"
    script "nf_pipeline/modules/TranslateToProtein.nf"
    process "TranslateToProtein"

    test("Should successfully translate CDS to protein sequences") {

        when {
            process {
                """
                def sampleId = "19135815"
                def cdsFiles = file("${projectDir}/tests/data/19135815/CDS/*_CDS.fasta")
                def alignedFiles = file("${projectDir}/tests/data/19135815/aligned_CDS/*_CDS_aligned.fasta")

                input[0] = [ sampleId, cdsFiles, alignedFiles ]
                """
            }
        }

        then {
            assert process.success
            assert process.out.results.size() > 0 && process.out.aligned.size() > 0
            
            def targetFile = path(process.out.results.get(0)[1].flatten().find { it.toString().endsWith("19135815_HA1_PROT.fasta") })
            def targetAlignedFile = path(process.out.aligned.get(0)[1].flatten().find { it.toString().endsWith("19135815_HA1_PROT_aligned.fasta") })
            
            assert targetFile.exists() && targetAlignedFile.exists()
            
            def proteinSeq = targetFile.text.split('>')[1].split('\n', 2)[1].replaceAll('\n', '')
            def refSeq = targetAlignedFile.text.split('>')[1].split('\n', 2)[1].replaceAll('\n', '')
            def querySeq = targetAlignedFile.text.split('>')[2].split('\n', 2)[1].replaceAll('\n', '')
            
            assert proteinSeq.toUpperCase().startsWith("DQICIGYHANN") : "Translation failure"
            assert refSeq.length() == querySeq.length() : "Alignment length mismatch"
            assert refSeq.toUpperCase().startsWith("DQICIGYHANN") : "Ref missing start motif"
            assert querySeq.toUpperCase().endsWith("REKRRKR") : "Query missing termination motif"
        }
    }
}