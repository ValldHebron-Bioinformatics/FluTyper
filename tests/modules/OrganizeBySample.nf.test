nextflow_process {

    name "Test Process OrganizeBySample"
    script "nf_pipeline/modules/OrganizeBySample.nf"
    process "OrganizeBySample"

    test("Should successfully split FASTA by sample and segment") {

        when {
            params {
                // Override the inputFasta to point to the test file
                inputFasta = "${projectDir}/tests/data/19135815/19135815.fasta"
            }
            process {
                """
                input[0] = "19135815"
                """
            }
        }

        then {
            assert process.success

            assert process.out.results != null
            assert process.out.results.size() > 0

            def sample_id = process.out.results[0][0]
            def out_dir = path(process.out.results[0][1])

            assert sample_id == "19135815"
            assert out_dir.resolve("19135815.fasta").exists()
            assert out_dir.resolve("segments/19135815_HA.fasta").exists()
            assert out_dir.resolve("segments/19135815_NA.fasta").exists()
            assert out_dir.resolve("segments/19135815_PB2.fasta").exists()
            assert out_dir.resolve("segments/19135815_MP.fasta").exists()
            assert out_dir.resolve("segments/19135815_NP.fasta").exists()
            assert out_dir.resolve("segments/19135815_PA.fasta").exists()
            assert out_dir.resolve("segments/19135815_PB1.fasta").exists()
            assert out_dir.resolve("segments/19135815_NS.fasta").exists()
            
            def HA = out_dir.resolve("segments/19135815_HA.fasta")
            assert HA.text.contains("atggagaacatagtacttcttcttgcaatagt")
        }
    }
    test("Should work with reverse complement sequences") {

        when {
            params {
                inputFasta = "${projectDir}/tests/data/19135815/19135815_rev.fasta"
            }
            process {
                """
                input[0] = "19135815"
                """
            }
        }

        then {
            assert process.success

            def out_dir = path(process.out.results[0][1])
            assert out_dir.resolve("segments/19135815_HA.fasta").exists()
            assert out_dir.resolve("segments/19135815_NA.fasta").exists()
            def HA = out_dir.resolve("segments/19135815_HA.fasta")
            assert HA.text.contains("atggagaacatagtacttcttcttgcaatagt")
        }
    }
}