nextflow_pipeline {

    name "Test Workflow FluTyper"
    script "nf_pipeline/main.nf"

    test("Should successfully execute the AVIAN protocol") {

        when {
            params {
                protocol = "AVIAN"
                protocols = [
                    AVIAN: [
                        resources : "${projectDir}/protocols/AVIAN/v1"
                    ]
                ]
                inputFasta = "${projectDir}/tests/data/test.fasta"
                outDir = "tests/results"
                metadata= "${projectDir}/tests/data/metadata.csv"
                IndividualReports = true
            }
        }

        then {
            assert workflow.success
            
            assert workflow.trace.succeeded().size() >= 10

            def outputDir = path("$baseDir/tests/results")

            def subtypeFile = outputDir.resolve("inferred_subtypes.csv")
            assert subtypeFile.exists() : "inferred_subtypes.csv was not published"
            assert subtypeFile.text.contains("19135815,H5N1,HPAI")

            def finalReport = outputDir.resolve("final_mutations_report.xlsx")
            assert finalReport.exists() : "final_mutations_report.xlsx was not published"
            
            def cladeGraphicReport = outputDir.resolve("graphic_reports/CladeGraphicReport.html")
            assert cladeGraphicReport.exists() : "CladeGraphicReport.html was not published"

            def mutationsGraphicReport = outputDir.resolve("graphic_reports/MutationsReport.html")
            assert mutationsGraphicReport.exists() : "MutationsReport.html was not published"

            def sampleMutationsCsv = outputDir.resolve("samples/19135815/19135815_mutations.csv")
            assert sampleMutationsCsv.exists() : "19135815_mutations.csv was not published"
            
            def csvText = sampleMutationsCsv.text
            
            assert csvText.contains("SAMPLE_ID,SUBTYPE,PROTEIN,REF_SUBTYPE,POSITION,POSITION_REF,REFERENCE_AA,QUERY_AA,AA_MUTATION,MUTATION_TYPE,MARKER,MARKER_ID,IS_COMBINATION,EFFECT,FOUND_IN,REFERENCE")

            // Updated to reflect standard substitutions actually present in the sample output dump
            assert csvText.contains('19135815,H5N1(HPAI),HA2,H5,181,181,V,I,V181I,Substitution,No,,No,,,')
            assert csvText.contains('19135815,H5N1(HPAI),HA2,H5,203,203,M,I,M203I,Substitution,No,,No,,,')
            assert csvText.contains('19135815,H5N1(HPAI),HA1,H5,104,104,M,L,M104L,Substitution,No,,No,,,')
            assert csvText.contains('19135815,H5N1(HPAI),M1,H5,137,137,T,A,T137A,Substitution,No,,No,,,')

            def individualGraphicReport = outputDir.resolve("samples/19135815/19135815_MutationsReport.html")
            assert individualGraphicReport.exists() : "19135815_MutationsReport.html was not published"
            assert individualGraphicReport.text.contains("<html")
            assert individualGraphicReport.text.contains("19135815")

            assert workflow.stdout.join('\n').contains("FluMutDB: Local database is up to date")
            
            def interactiveTableReport = outputDir.resolve("graphic_reports/MutationsTable.html")
            assert interactiveTableReport.exists() : "MutationsTable.html was not published"
        }
    }

    test("Should fail when the SWINE protocol is selected") {

        when {
            params {
                protocol = "SWINE"
                inputFasta = "${projectDir}/tests/data/test.fasta"
                outDir = "tests/results"
            }
        }

        then {
            assert workflow.failed
            assert workflow.stdout.join('\n').contains("PROTOCOL ERROR: The SWINE protocol is currently under development")
        }
    }

    test("Should succeed with the HUMAN protocol") {
        when {
            params {
                protocol = "HUMAN"
                protocols = [
                    HUMAN: [
                        resources : "${projectDir}/protocols/HUMAN/v1"
                    ]
                ]
                inputFasta = "${projectDir}/tests/data/HUMAN.fasta"
                outDir = "tests/results"
                metadata= "${projectDir}/tests/data/humanmetadata.csv"
                IndividualReports = true
            }
        }

        then {
            assert workflow.success
            
            assert workflow.trace.succeeded().size() >= 10

            def outputDir = path("$baseDir/tests/results")

            def subtypeFile = outputDir.resolve("inferred_subtypes.csv")
            assert subtypeFile.exists() : "inferred_subtypes.csv was not published"
            
            // Updated to expect the proper A(H3N2) nomenclature generated by the pipeline
            assert subtypeFile.text.contains("198353883,A(H3N2),")

            def finalReport = outputDir.resolve("final_mutations_report.xlsx")
            assert finalReport.exists() : "final_mutations_report.xlsx was not published"

            def cladeGraphicReport = outputDir.resolve("graphic_reports/CladeGraphicReport.html")
            assert cladeGraphicReport.exists() : "CladeGraphicReport.html was not published"

            def mutationsGraphicReport = outputDir.resolve("graphic_reports/MutationsReport.html")
            assert mutationsGraphicReport.exists() : "MutationsReport.html was not published"

            def sampleMutationsCsv = outputDir.resolve("samples/198353883/198353883_mutations.csv")
            assert sampleMutationsCsv.exists() : "198353883_mutations.csv was not published"
            
            def csvText = sampleMutationsCsv.text
            
            assert csvText.contains("SAMPLE_ID,SUBTYPE,PROTEIN,REF_SUBTYPE,POSITION,POSITION_REF,REFERENCE_AA,QUERY_AA,AA_MUTATION,MUTATION_TYPE,MARKER,MARKER_ID,IS_COMBINATION,EFFECT,FOUND_IN,REFERENCE")

            // Updated these strings to also expect A(H3N2) in the SUBTYPE column
            assert csvText.contains('198353883,A(H3N2),M2,A(H3N2),1,1,M,E,M1E,Substitution,No,,No,,,')
            assert csvText.contains('198353883,A(H3N2),HA1,A(H3N2),189,186,K,R,K189R,Marker,Yes,176 | 362,No,EPITOP(B) | EPITOP(RBD - 180LOOP),H3N2,')
            
            def individualGraphicReport = outputDir.resolve("samples/198353883/198353883_MutationsReport.html")
            assert individualGraphicReport.exists() : "198353883_MutationsReport.html was not published"
            assert individualGraphicReport.text.contains("<html")
            assert individualGraphicReport.text.contains("198353883")

            def interactiveTableReport = outputDir.resolve("graphic_reports/MutationsTable.html")
            assert interactiveTableReport.exists() : "MutationsTable.html was not published"
        }
    }

    test("Should successfully execute append mode and generate optional geographic/temporal reports") {

        when {
            params {
                protocol = "HUMAN"
                protocols = [
                    HUMAN: [
                        resources : "${projectDir}/protocols/HUMAN/v1"
                    ]
                ]
                inputFasta = "${projectDir}/tests/data/HUMAN.fasta"
                outDir = "tests/results_append_geo"
                
                // Gatekeeper parameters for the Reporting modules
                metadata = "${projectDir}/tests/data/humanmetadata.csv"
                coordinates = "${projectDir}/tests/data/Graphs_test/coordenades_cat.tsv"
                
                // Trigger the MergeHistoricalData process
                append = "${projectDir}/tests/data/append_dir"
            }
        }

        then {
            assert workflow.success
            
            def outputDir = path("$baseDir/tests/results_append_geo")

            // Validate that the gatekeeper parameters successfully triggered the Geographic map
            def geographicReport = outputDir.resolve("graphic_reports/GeographicReport.html")
            assert geographicReport.exists() : "GeographicReport.html was not published"
            
            // Validate that the gatekeeper parameters successfully triggered the Date report
            def evolutionDir = outputDir.resolve("graphic_reports/FrequencyEvolution")
            assert evolutionDir.exists() : "FrequencyEvolution directory was not published"
            
            // Verify the appended data output files contain the expected historical entries
            def inferredSubtypes = outputDir.resolve("inferred_subtypes.csv")
            assert inferredSubtypes.exists() : "Appended subtypes file was not published"
            assert inferredSubtypes.text.contains("101627772,A(H3N2),")
            assert inferredSubtypes.text.contains("198217653,A(H3N2),")
            
            def finalGenotyping = outputDir.resolve("final_genotyping_results.csv")
            assert finalGenotyping.exists() : "Appended genotyping file was not published"
            assert finalGenotyping.text.contains("198217653,A(H3N2),nextclade_H3_dataset,2026-04-14T11:55:23Z,G.1.3,-,-,-,-")
            assert finalGenotyping.text.contains("101627772,A(H3N2),nextclade_H3_dataset,2026-04-14T11:55:23Z,G.1,-,-,-,-")

            assert outputDir.resolve("final_mutations_report.xlsx").exists() : "Appended mutations file was not published"
        }
    }
}
