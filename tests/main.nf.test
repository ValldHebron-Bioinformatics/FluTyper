nextflow_pipeline {

    name "Test Workflow FluTyper"
    script "nf_pipeline/main.nf"

    test("Should successfully execute the AVIAN protocol") {

        when {
            params {
                protocol = "AVIAN"
                protocols = [
                    AVIAN: [
                        resources : "${projectDir}/protocols/AVIAN/v1"
                    ]
                ]
                inputFasta = "${projectDir}/tests/data/test.fasta"
                outDir = "tests/results"
            }
        }

        then {
            assert workflow.success
            
            // Verify that a sufficient number of tasks completed successfully (channels from the publish block)
            assert workflow.trace.succeeded().size() >= 10

            // Define the output directory
            def outputDir = path("$baseDir/tests/results")

            // Precise check for the subtype CSV without snapshots
            def subtypeFile = outputDir.resolve("inferred_subtypes.csv")
            assert subtypeFile.exists() : "inferred_subtypes.csv was not published"
            assert subtypeFile.text.contains("19135815,H5N1,HPAI")

            // Excel Validation targeting sharedStrings.xml directly
            def finalReport = outputDir.resolve("final_mutations_report.xlsx")
            assert finalReport.exists() : "final_mutations_report.xlsx was not published"
            
            // Added xl/sharedStrings.xml to prevent buffer overload
            def cmd = "unzip -p ${finalReport} xl/sharedStrings.xml"
            def excelText = cmd.execute().text
            assert excelText.contains("Increased viral replication in mice lungs")
            assert excelText.contains("Zhang J. et al., 2023")

            def relevantReport = outputDir.resolve("relevant_mutations.xlsx")
            assert relevantReport.exists() : "relevant_mutations.xlsx was not published"
            
            // Added xl/sharedStrings.xml to prevent buffer overload
            def relevantText = "unzip -p ${relevantReport} xl/sharedStrings.xml".execute().text
            assert relevantText.contains("Decreased virulence in ducks")
            assert relevantText.contains("Conenello G. et al., 2007")

            // Check standard output for the database version log
            assert workflow.stdout.join('\n').contains("FluMutDB: Local database is up to date")
        }
    }

    test("Should fail when the SWINE protocol is selected") {

        when {
            params {
                protocol = "SWINE"
                inputFasta = "${projectDir}/tests/data/test.fasta"
                outDir = "tests/results"
            }
        }

        then {
            assert workflow.failed
            
            // Check the exact error message from your main.nf 'exit 1' call
            assert workflow.stdout.join('\n').contains("PROTOCOL ERROR: The SWINE protocol is currently under development")
        }
    }
}