nextflow_process {
    name "Test MutationsFinder"
    script "nf_pipeline/modules/MutationsFinder.nf"
    process "MutationsFinder"

    options "-profile ci"

    test("Mutations found and PB2 markers annotated for H5N1 HPAI") {
        when {
            params {
                protocol = "AVIAN"
                protocols = [
                    AVIAN: [
                        resources: "${projectDir}/protocols/AVIAN/v1"
                    ]
                ]
                programs = [
                    MutationsDictionary: "${projectDir}/nf_pipeline/bin/MutationsDictionary.py"
                ]
            }
            process {
                """
                input[0] = [
                    "19135815",
                    [
                        file("${projectDir}/tests/fixtures/proteins/19135815_PB2_PROT.fasta"),
                        file("${projectDir}/tests/fixtures/proteins/19135815_HA-SP_PROT.fasta")
                    ],
                    "H5", "N1", "HPAI"
                ]
                """
            }
        }
        then {
            assert process.success
            def csv = path(process.out.results[0][2]).text
            assert csv.contains("SAMPLE_ID")
            assert csv.contains("PB2")
            assert csv.contains("HA-SP")
            assert csv.contains(",TRUE,")
        }
    }
}
