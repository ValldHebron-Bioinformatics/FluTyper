nextflow_process {
    name "Test MutationsCompiler"
    script "nf_pipeline/modules/MutationsCompiler.nf"
    process "MutationsCompiler"

    test("Both Excel files are produced") {
        when {
            process {
                """
                input[0] = [
                    file("${projectDir}/tests/fixtures/compiler_s1.csv"),
                    file("${projectDir}/tests/fixtures/compiler_s2.csv")
                ]
                """
            }
        }
        then {
            assert process.success
            assert path(process.out.results[0][0]).exists()
            assert path(process.out.results[0][1]).exists()
            assert path(process.out.results[0][0]).size() > 0
            assert path(process.out.results[0][1]).size() > 0
        }
    }

    test("Relevant report is filtered: rare non-marker positions excluded") {
        when {
            process {
                """
                input[0] = [
                    file("${projectDir}/tests/fixtures/compiler_s1.csv"),
                    file("${projectDir}/tests/fixtures/compiler_s2.csv")
                ]
                """
            }
        }
        then {
            assert process.success
            // relevant_mutations.xlsx should be strictly smaller than full report
            // because position 999 (count=1, not a marker, not > 10% of 10 samples) is filtered out
            assert path(process.out.results[0][1]).size() < path(process.out.results[0][0]).size()
        }
    }
}
