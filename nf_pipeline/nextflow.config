manifest {
  name = 'FluTyper'
  author = 'Alejandra González-Sánchez & Marc Pérez i Bautista'
  homePage = 'https://github.com/[UPDATE]'
  description = 'Pipeline for Influenza genotyping and analysis'
  mainScript = 'main.nf'
}

params {
  help = null
  version = "1.1.0"
  phredScore = 30
  workDir = "/home/vhir/Desktop/FluTyper/nf_pipeline" // Update this path to our working directory in MICRO server, but for now we will use this one for testing purposes.
  protocol = null
 // YET TO SET UP PROTOCOLS
  protocolsDir = "/gpfs/GENOM01/MICRO/Virologia/viruses/gripe/projects/FluTyper/protocols"
  protocols = [
    H5: [
      directory : "${params.protocolsDir}/H5",
      resources : "${params.protocolsDir}/H5/resources"      
    ],
    H7: [
      directory : "${params.protocolsDir}/H7",
      resources : "${params.protocolsDir}/H7/resources"      
    ]
  ]
 
  programs = [
    extractClades : "bin/extract_clades.py",
    createCSV : "bin/CSVFileCreation.py"
  
  ]
  sample = "*.fasta" // Nom del fitxer d'entrada per defecte, es pot sobreescriure amb --sample
  dirSample = "/home/vhir/Desktop/FluTyper/docs/fastas"
}
process {
  withLabel: 'big_mem' {
    cpus = 16
    memory = 32.GB
    maxForks = 4
  }
}


