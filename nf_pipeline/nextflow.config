manifest {
  name = 'FluTyper'
  author = 'Alejandra González-Sánchez & Marc Pérez i Bautista'
  homePage = 'https://github.com/[UPDATE]'
  description = 'Pipeline for Influenza genotyping and analysis'
  mainScript = 'main.nf'
}
params {
  help = null
  version = "1.1.0"
  protocol = "AVIAN" // Default protocol
  protocols = [
    AVIAN: [
      directory : "${projectDir}/../protocols/AVIAN",
      resources : "${projectDir}/../protocols/AVIAN/v1"      
    ],
    SWINE: [
      directory : "${projectDir}/../protocols/SWINE",
      resources : "${projectDir}/../protocols/SWINE/v1"      
    ],
    HUMAN: [
      directory : "${projectDir}/../protocols/HUMAN",
      resources : "${projectDir}/../protocols/HUMAN/v1"      
    ]
  ]
  segments = ["HA","NA","PB2","PB1","PA","NP","MP","NS"]
  extraMarkers = null
  inputFasta = "${projectDir}/../docs/fastas/cresaid.fasta // Default inputFasta
  outDir = "RESULTS"
  threshold = 0.25 // Default threshold, can be overridden with --threshold
  colorblind = false // Whether to use colorblind-friendly palettes in reports, can be set with --colorblind
  metadata = null // Path to metadata file, can be set with --metadata
  IndividualReports = false // Whether to generate individual reports for each sample, can be set with --IndividualReports
  append = null // Whether to append results to existing output, can be set with --append
}

// Local execution configuration
executor {
  name = 'local'
  cpus = 18        // Use 18 threads, leave 2 for the operating system
  memory = 13.GB // Strictly limit total Nextflow RAM to prevent OS crashing
}

process {
  cpus = 1
  memory = 2.GB

  withLabel: 'big_mem' {
    cpus = 12        
    memory = 10.GB  
    maxForks = 1      
  }
}
profiles {
  ci {
    process {
      // Catch-all for standard processes
      cpus = 1
      memory = 4.GB
      maxRetries = 1
      
      withLabel: 'big_mem' {
        cpus = 2
        memory = 6.GB
        maxForks = 1
      }
    }
  }
}



